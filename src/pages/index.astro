---
import PaginaMaestra1 from "./layouts/PaginaMaestra1.astro"
---
<PaginaMaestra1>
    <div id="ContenedorPrin"> 
        <div class="pizarrap">
            <img src="/portada/pizarrap.svg" alt="Pizarra">
        </div>
            
            <div class="botonp">
                 <a class="botonpa" href="/indice">
                    <img class="botonpimg" src="/portada/botonp.png" alt="Botón de Inicio">
                </a>
            </div>
        <div class="personaje">
           <img src="/portada/lp.svg" alt="Personaje">
        </div>
        <div class="deco">
            <img src="/portada/decop.svg">
        </div>
  </div>




<style>
    button {
background: transparent;
border: none;
padding: 0;
margin: 0;
font: inherit;
color: inherit;
cursor: pointer;
outline: none;
}
    .deco img {
        width: 150%;
        right: 12%;

        position: relative;
    }
    .deco {
        overflow: visible;
        display: flex;
        justify-content: flex-end;
        grid-column: 1/20;
        grid-row: 6/12;
        width: 120%;
        height: 100%;
        z-index: 1;

    }
    .personaje img {

        padding-top: 4%;
        height: 80%;
        padding-right: 8%;
        padding-top: 10%;
        object-fit: fill;
        


    }
    .personaje {
        
        grid-column: 2/9;
        grid-row: 5/14;
        width: 100%;
        display: flex;
        z-index: 3;
        justify-content: flex-end;
    }
    .botonpa {
        position: relative;
        display: inline-block;
        width: fit-content;
    }
    .botonpimg {
        transition: transform 0.2s ease;
        width: 70%;
        position: relative;
        padding-left: 4%;
        padding-bottom: 6%;

    }

        .botonpimg:hover{
        transform: scale(1.1);
    }

    .botonp {
        margin-right: 20%;
        display: flex;
        justify-content: center;
        align-items: center;
        grid-column: 18/23;
        grid-row: 9/12;
        width: 100%;
        height: 100%;
        z-index: 10 !important;
    }
    .pizarrap {
        grid-column: 9/31;
        grid-row: 2/11;
        width: 100%;
        height: 100%;
        z-index: 3;
    }

    #ContenedorPrin {
            display: grid;
            width: 1400px;
            height: 650px;
            overflow: visible;

        

            /* Definición de Columnas: 30 módulos de 41.12px y 29 medianiles de 5.74px */
            grid-template-columns: repeat(30, 41.12px);
            column-gap: 5.74px;

            /* Definición de Filas: 14 módulos de 41.12px y 13 medianiles de 5.74px */
            grid-template-rows: repeat(14, 41.12px);
            row-gap: 5.74px;

            /* Opcional: para visualizar la retícula durante el diseño */
            /* outline: 1px solid red; 
    background-image: 
        linear-gradient(to right, rgba(0,0,0,0.1) 41.12px, transparent 5.74px),
        linear-gradient(to bottom, rgba(0,0,0,0.1) 41.12px, transparent 5.74px);
    background-size: calc(41.12px + 5.74px) calc(41.12px + 5.74px); */
        }
</style>
        
</PaginaMaestra1>