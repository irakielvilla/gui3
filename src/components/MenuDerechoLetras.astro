    <a href="/c-grafomotriz/letras1/letras1-1/" class="btn-numero">
      <img id="numero1" src={integerNumber === 1 ? "/barraderecha/11si.svg" : "/barraderecha/11l.svg"} alt="Número 0"/>
    </a>
    <a href="/c-grafomotriz/letras1/letras1-2/" class="btn-numero">
      <img src={integerNumber === 2 ? "/barraderecha/12si.svg" : "/barraderecha/12l.svg"} alt="Número 1" />
    </a>
    <a href="/c-grafomotriz/letras1/letras1-3/" class="btn-numero">
      <img src={integerNumber === 3 ? "/barraderecha/13si.svg" : "/barraderecha/13l.svg"} alt="Número 2" />
    </a>
    <a href="/c-grafomotriz/letras1/letras1-4/" class="btn-numero">
      <img src={integerNumber === 4 ? "/barraderecha/14si.svg" : "/barraderecha/14l.svg"} alt="Número 3" />
    </a>
    <a href="/c-grafomotriz/letras1/letras1-5/" class="btn-numero">
      <img src={integerNumber === 5 ? "/barraderecha/15lsi.svg" : "/barraderecha/15l.svg"} alt="Número 4" />
