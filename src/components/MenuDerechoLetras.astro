  </div>

  {/* BLOQUE 2 (Páginas 6 a 10) */}
  <div id="grupo-numeros-2" class="bloque-numeros oculto">
    <a href="/c-grafomotriz/letras1/letras1-6/" class="btn-numero">
      <img src={integerNumber === 6 ? "/barraderecha/16lsi.svg" : "/barraderecha/16l.svg"} alt="Número 5" />
    </a>
    <a href="/c-grafomotriz/letras1/letras1-7/" class="btn-numero">
      <img src={integerNumber === 7 ? "/barraderecha/17lsi.svg" : "/barraderecha/17l.svg"} alt="Número 6" />
    </a>
    <a href="/c-grafomotriz/letras1/letras1-8/" class="btn-numero">
      <img src={integerNumber === 8 ? "/barraderecha/18lsi.svg" : "/barraderecha/18l.svg"} alt="Número 7" />
    </a>
    <a href="/c-grafomotriz/letras1/letras1-9/" class="btn-numero">
      <img src={integerNumber === 9 ? "/barraderecha/19lsi.svg" : "/barraderecha/19l.svg"} alt="Número 8" />
    </a>
    <a href="/c-grafomotriz/letras1/letras1-10/" class="btn-numero">
      <img id="numero10" src={integerNumber === 10 ? "/barraderecha/20lsi.svg" : "/barraderecha/20l.svg"} alt="Número 9" />
    </a>
  </div>

  {/* BLOQUE 3 NUEVO (Página 11 - Un solo botón) */}
  <div id="grupo-numeros-3" class="bloque-numeros oculto">
    <a id="numero11a" href="/c-grafomotriz/letras1/letras1-11/" class="btn-numero">
      {/* ⚠️ Recuerda cambiar estos nombres por los assets reales de tu botón 11 si los tienes */}
