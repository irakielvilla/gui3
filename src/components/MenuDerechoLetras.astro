---
// Componente: MenuDerechoNumeros.astro
const { currentNumber, miejercicio } = Astro.props;

// 1. Limpieza a prueba de balas: Extraemos el número final (blindado contra barras "/" o espacios)
const stringCrudo = String(currentNumber || miejercicio?.id || '');
const numeroExtraido = stringCrudo.match(/(\d+)\D*$/);
const integerNumber = numeroExtraido ? parseInt(numeroExtraido[1], 10) : 0;

// 2. Astro decide qué bloque mostrar primero según el número real de la página
let paginaInicialMenu = 1;

if (integerNumber >= 1 && integerNumber <= 5) {
  paginaInicialMenu = 1;
} else if (integerNumber >= 6 && integerNumber <= 10) {
  paginaInicialMenu = 2;
} else if (integerNumber >= 11) {
  paginaInicialMenu = 3;
}

// 🔔 ALARMAS DE ASTRO (Se ven en tu terminal)
console.log("-----------------------------------------");
console.log("🚨 ALARMA 1: Prop currentNumber:", currentNumber);
console.log("🚨 ALARMA 2: Prop miejercicio?.id:", miejercicio?.id);
console.log("🚨 ALARMA 3: stringCrudo evaluado:", stringCrudo);
console.log("🚨 ALARMA 4: integerNumber final:", integerNumber);
console.log("🚨 ALARMA 5: paginaInicialMenu calculada:", paginaInicialMenu);
console.log("-----------------------------------------");
---

<div id="barraderecha" class="menu-interactivo-numeros" data-pagina-inicial={paginaInicialMenu}>
  
  <button id="btn-arriba" class="btn-flecha" title="Ver números anteriores">
    <img src="/barraderecha/arribadere.svg" alt="Flecha Arriba" />
  </button>

  {/* BLOQUE 1 (Páginas 1 a 5) */}
