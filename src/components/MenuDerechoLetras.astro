    </a>
  </div>

  <button id="btn-abajo" class="btn-flecha" title="Ver siguientes números">
    <img src="/barraderecha/abajodere.svg" alt="Flecha Abajo" />
  </button>

</div>

<style>
  #numero11a{
    margin-bottom: 75%;
  }
  :global(a) {
        position: relative;
        display: inline-block;
        width: fit-content;
  }

  #grupo-numeros-1 img{
    width: 125%;
    position: relative;

  }
  #grupo-numeros-2 img{
    width: 125%;
    position: relative;
  }
   #grupo-numeros-3 img{
    width: 148%;
    position: relative;
    right: 10%;
  }
  #btn-arriba{
    margin-bottom: -30%;
    width: 60%;
  }
  #btn-abajo{
    width: 60%;
  }

  #numero1{
    height: 80% !important; 
  }

  #numero10{
    width: 152% !important; 
  }
  /* Contenedor principal que se alinea con tu Grid */
  .menu-interactivo-numeros {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between !important;
    gap: 0px; /* Espacio entre flechas y números */
    width: 100%;
    height: 100%;
    grid-column: 26/31;
    grid-row: 5/15;
  }

  /* Estilos para limpiar los botones nativos y hacerlos interactivos */
  .btn-flecha {
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .btn-flecha img {
    width: 22%; /* Ajusta el tamaño de tus flechas aquí */
    height: auto;
  }

  /* 🚀 LA MAGIA: Clase que desactiva la flecha cuando topamos el límite */
  .desactivado {
    opacity: 0.3; /* Se vuelve semitransparente */
    pointer-events: none; /* Bloquea el clic */
    cursor: default;
  }

  /* Estilos para los bloques de números */
  .bloque-numeros {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15.5%; /* Espacio entre cada número */
    width: 100%;
    position: relative; /* Para posicionar las flechas dentro del bloque */
    bottom: 8%;
  }

  /* Clase para ocultar el bloque que no se está viendo */
  .oculto {
    display: none;
  }

  .btn-numero {
    display: block;
    width: 22.5%; /* Ajusta según lo ancho que quieras los números */
    transition: transform 0.2s ease;
    padding-right: 7%;

  }

  .btn-numero img {
    width: 120%;
    height: auto;
    object-fit: contain;
  }

  /* Efecto sutil al pasar el mouse por encima de los números */
  .btn-numero:hover, .btn-flecha:hover:not(.desactivado) {
    transform: scale(1.25);
    transform-origin: center center !important;
  }
</style>

<script>
  const inicializarMenuDerecho = () => {
    console.log("🚀 ALARMA CLIENTE: Inicializando script de 3 bloques...");
    
    const menuContainer = document.querySelector('.menu-interactivo-numeros');
    if (!menuContainer) return;

    const paginaInicial = parseInt(menuContainer.getAttribute('data-pagina-inicial') || '1', 10);

    const btnArriba = document.getElementById('btn-arriba');
    const btnAbajo = document.getElementById('btn-abajo');
    const grupo1 = document.getElementById('grupo-numeros-1');
    const grupo2 = document.getElementById('grupo-numeros-2');
    const grupo3 = document.getElementById('grupo-numeros-3');

    // Validación estricta incluyendo el nuevo grupo 3
    if (!btnArriba || !btnAbajo || !grupo1 || !grupo2 || !grupo3) {
        console.error("❌ ERROR CRÍTICO: Falta algún elemento en el HTML.");
        return;
    }

    let paginaActualMenu = paginaInicial;

    const actualizarVistaMenu = () => {
      console.log("🔄 Cambiando vista del menú al Bloque:", paginaActualMenu);
      
      // 1. Ocultamos todos los grupos por defecto
      grupo1.classList.add('oculto');
      grupo2.classList.add('oculto');
      grupo3.classList.add('oculto');
      
      // 2. Encendemos todas las flechas por defecto (Mantiene activo el Bloque Central)
      btnArriba.classList.remove('desactivado');
      btnAbajo.classList.remove('desactivado');

      // 3. Aplicamos excepciones por bloque
      if (paginaActualMenu === 1) {
        grupo1.classList.remove('oculto');
        btnArriba.classList.add('desactivado'); // Bloque superior: no sube más
      } else if (paginaActualMenu === 2) {
        grupo2.classList.remove('oculto');
        // Bloque central: Ambas flechas se quedan activas automáticamente
      } else if (paginaActualMenu === 3) {
        grupo3.classList.remove('oculto');
        btnAbajo.classList.add('desactivado'); // Bloque inferior: no baja más
      }
    };

    actualizarVistaMenu();

    // Comportamiento de clics infinito/secuencial controlado
    btnArriba.addEventListener('click', () => {
      if (paginaActualMenu > 1) {
        paginaActualMenu--;
        actualizarVistaMenu();
      }
    });

    btnAbajo.addEventListener('click', () => {
      if (paginaActualMenu < 3) {
        paginaActualMenu++;
        actualizarVistaMenu();
      }
    });
  };

  document.addEventListener("DOMContentLoaded", inicializarMenuDerecho);
  document.addEventListener("astro:page-load", inicializarMenuDerecho);
</script>